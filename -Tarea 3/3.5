#include <stdio.h>

int main()
{
    int NUM;

    printf("Ingresa el numero para calcular la serie: ");
    scanf("%d", &NUM);

    if (NUM > 0)
    {
        printf("\nSerie de ULAM\n");
        printf("%d\t", NUM);

        while (NUM != 1)
        {
            if (NUM % 2 == 0)
            {
                NUM = NUM / 2;
            }
            else
            {
                NUM = NUM * 3 + 1;
            }

            printf("%d\t", NUM);
        }
    }
    else
    {
        printf("\nNUM debe ser un entero positivo");
    }

    return 0;
